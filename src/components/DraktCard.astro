---
import type { Drakt } from "../types";

interface Props {
  drakt: Drakt;
}

const { drakt } = Astro.props;
const hasImage = drakt.bildeUrl && !drakt.bildeUrl.includes("illustrasjon");
---

<a href={`/drakt/${drakt.id}`} class="card">
  <div class="card-image">
    {hasImage ? (
      <img src={drakt.bildeUrl} alt={drakt.navn} loading="lazy" />
    ) : (
      <div class="placeholder">⚽</div>
    )}
  </div>
  <div class="card-body">
    <h3 class="card-title">{drakt.navn}</h3>
    {drakt.aar && <p class="card-year">{drakt.aar}</p>}
    <div class="card-meta">
      {drakt.land && <span class="tag">{drakt.land}</span>}
      {drakt.typeLag && <span class="tag tag-type">{drakt.typeLag}</span>}
    </div>
    {drakt.farge && <p class="card-color">{drakt.farge}</p>}
    {drakt.informasjon && <p class="card-info">{drakt.informasjon}</p>}
  </div>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: box-shadow 0.2s, transform 0.2s;
    text-decoration: none;
    color: inherit;
  }

  .card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .card-image {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .placeholder {
    font-size: 2rem;
    opacity: 0.2;
  }

  .card-body {
    padding: 0.75rem 1rem 1rem;
    flex: 1;
  }

  .card-title {
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 0.15rem;
    line-height: 1.3;
  }

  .card-year {
    font-size: 0.8rem;
    color: var(--color-muted);
    margin-bottom: 0.4rem;
  }

  .card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-bottom: 0.4rem;
  }

  .tag {
    display: inline-block;
    font-size: 0.7rem;
    background: var(--color-accent-light, #e8f5e9);
    color: var(--color-accent);
    padding: 0.1rem 0.45rem;
    border-radius: 3px;
    font-weight: 500;
  }

  .tag-type {
    background: #f0fdf4;
    color: #1b5e20;
  }

  .card-color {
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  .card-info {
    font-size: 0.78rem;
    color: var(--color-muted);
    margin-top: 0.25rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
</style>
