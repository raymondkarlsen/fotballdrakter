---
import type { Drakt } from "../types";

interface Props {
  drakt: Drakt;
}

const { drakt } = Astro.props;
const hasImage = drakt.bildeUrl && !drakt.bildeUrl.includes("illustrasjon");

// Fargemapping til CSS-farger for placeholder
const fargeMap: Record<string, string> = {
  blå: "#2563eb",
  brun: "#78350f",
  burgunder: "#7f1d1d",
  grå: "#6b7280",
  grønn: "#16a34a",
  gul: "#eab308",
  gull: "#d4a017",
  hvit: "#f1f5f9",
  lilla: "#7c3aed",
  oransje: "#ea580c",
  rosa: "#ec4899",
  rød: "#dc2626",
  svart: "#1f2937",
};

// Hent opptil 3 farger for gradient-placeholder
const draktFarger = drakt.farge
  .split(",")
  .map((f) => f.trim())
  .filter(Boolean)
  .map((f) => fargeMap[f] || "#94a3b8")
  .slice(0, 3);

function buildGradient(farger: string[]): string {
  if (farger.length === 0) return "#e2e8f0";
  if (farger.length === 1) return farger[0];
  return `linear-gradient(135deg, ${farger.join(", ")})`;
}

// Landskode til flaggemoji
function landskodeTilFlagg(kode: string): string {
  if (!kode) return "";
  // Håndter sammensatte koder som gb-eng, gb-wls, gb-sct
  const parts = kode.split("-");
  if (parts[0] === "gb" && parts.length > 1) {
    // For UK-subregioner bruker vi flagg-emojis via tag sequences
    const subFlags: Record<string, string> = {
      eng: "🏴󠁧󠁢󠁥󠁮󠁧󠁿",
      wls: "🏴󠁧󠁢󠁷󠁬󠁳󠁿",
      sct: "🏴󠁧󠁢󠁳󠁣󠁴󠁿",
    };
    return subFlags[parts[1]] || "🇬🇧";
  }
  // Standard landskode → flaggemoji via regional indicator symbols
  const base = parts[0].toUpperCase();
  if (base.length !== 2) return "";
  return String.fromCodePoint(
    ...base.split("").map((c) => 0x1f1e6 + c.charCodeAt(0) - 65)
  );
}

const flagg = landskodeTilFlagg(drakt.landskode);
---

<a href={`${import.meta.env.BASE_URL}/drakt/${drakt.id}`} class="card">
  <div class="card-image">
    {hasImage ? (
      <img src={drakt.bildeUrl} alt={drakt.navn} loading="lazy" />
    ) : (
      <div class="placeholder" style={`background: ${buildGradient(draktFarger)}`}>
        <span class="placeholder-icon">👕</span>
      </div>
    )}
  </div>
  <div class="card-body">
    <h3 class="card-title">{drakt.navn}</h3>
    {drakt.aar && <p class="card-year">{drakt.aar}</p>}
    <div class="card-meta">
      {drakt.land && <span class="tag">{flagg && <span class="flag">{flagg}</span>}{drakt.land}</span>}
      {drakt.typeLag && <span class={`tag tag-${drakt.typeLag.toLowerCase()}`}>{drakt.typeLag}</span>}
    </div>
    {drakt.informasjon && <p class="card-info">{drakt.informasjon}</p>}
  </div>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: box-shadow 0.2s, transform 0.2s;
    text-decoration: none;
    color: inherit;
  }

  .card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .card-image {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .placeholder-icon {
    font-size: 2.5rem;
    opacity: 0.4;
    filter: grayscale(1) drop-shadow(0 2px 4px rgba(0, 0, 0, 0.15));
  }

  .card-body {
    padding: 0.75rem 1rem 1rem;
    flex: 1;
  }

  .card-title {
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 0.15rem;
    line-height: 1.3;
  }

  .flag {
    font-size: 0.85rem;
    margin-right: 0.2rem;
    line-height: 1;
  }

  .card-year {
    font-size: 0.8rem;
    color: var(--color-muted);
    margin-bottom: 0.4rem;
  }

  .card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-bottom: 0.4rem;
    align-items: center;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    font-size: 0.7rem;
    background: #f0f5f1;
    color: var(--color-text);
    padding: 0.2rem 0.45rem;
    border-radius: 3px;
    font-weight: 500;
    line-height: 1;
    min-height: 1.3rem;
  }

  .tag-type {
    background: #f0f5f1;
  }

  .tag-klubb {
    background: #eff6ff;
  }

  .tag-land {
    background: #ecfdf5;
  }

  .tag-fiksjon {
    background: #f4f4f5;
  }

  .card-info {
    font-size: 0.78rem;
    color: var(--color-muted);
    margin-top: 0.25rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .card-image {
      aspect-ratio: 3 / 2;
    }

    .placeholder-icon {
      font-size: 1.75rem;
    }

    .card-body {
      padding: 0.5rem 0.65rem 0.65rem;
    }

    .card-title {
      font-size: 0.8rem;
    }

    .card-year {
      font-size: 0.7rem;
      margin-bottom: 0.2rem;
    }

    .card-meta {
      margin-bottom: 0.2rem;
    }

    .tag {
      font-size: 0.6rem;
      padding: 0.05rem 0.35rem;
    }

    .card-info {
      display: none;
    }
  }
</style>
