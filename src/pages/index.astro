---
import Base from "../layouts/Base.astro";
import DraktCard from "../components/DraktCard.astro";
import drakter from "../data/drakter.json";
import type { Drakt } from "../types";

const allDrakter = drakter as Drakt[];

// Statistikk
const antallLand = new Set(allDrakter.map((d) => d.land).filter(Boolean)).size;
const klubbdrakter = allDrakter.filter((d) => d.typeLag === "Klubb").length;
const landslagsdrakter = allDrakter.filter((d) => d.typeLag === "Land").length;

// Topp 10 land
const landCount = allDrakter.reduce((acc, d) => {
  if (d.land) acc[d.land] = (acc[d.land] || 0) + 1;
  return acc;
}, {} as Record<string, number>);
const topp10Land = Object.entries(landCount)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 10);

// Topp 10 klubber (kun de med flere drakter)
const klubbCount = allDrakter.reduce((acc, d) => {
  if (d.navn) acc[d.navn] = (acc[d.navn] || 0) + 1;
  return acc;
}, {} as Record<string, number>);
const topp10Klubber = Object.entries(klubbCount)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 10);

// Filteralternativer
const land = [...new Set(allDrakter.map((d) => d.land).filter(Boolean))].sort();
const typer = [...new Set(allDrakter.map((d) => d.typeLag).filter(Boolean))].sort();
const farger = [...new Set(
  allDrakter.flatMap((d) => d.farge.split(",").map((f) => f.trim())).filter(Boolean)
)].sort();

// Tiår
const tiaar = [...new Set(
  allDrakter
    .flatMap((d) => {
      const years = d.aar.match(/\d{4}/g);
      return years ? years.map((y) => `${Math.floor(parseInt(y) / 10) * 10}`) : [];
    })
    .filter(Boolean)
)].sort();
---

<Base title="Fotballdrakter – Min samling">
  <section class="hero">
    <h1>Min fotballdraktsamling</h1>
    <p>En oversikt over {allDrakter.length} fotballdrakter fra hele verden.</p>
  </section>

  <!-- Statistikk -->
  <section class="stats">
    <div class="stat-cards">
      <div class="stat-card">
        <span class="stat-number">{allDrakter.length}</span>
        <span class="stat-label">Drakter totalt</span>
      </div>
      <div class="stat-card">
        <span class="stat-number">{antallLand}</span>
        <span class="stat-label">Land</span>
      </div>
      <div class="stat-card">
        <span class="stat-number">{klubbdrakter}</span>
        <span class="stat-label">Klubbdrakter</span>
      </div>
      <div class="stat-card">
        <span class="stat-number">{landslagsdrakter}</span>
        <span class="stat-label">Landslagsdrakter</span>
      </div>
    </div>

    <div class="stat-lists">
      <div class="stat-list">
        <h3>Topp 10 land</h3>
        <ol>
          {topp10Land.map(([name, count]) => (
            <li><span class="list-name">{name}</span><span class="list-count">{count}</span></li>
          ))}
        </ol>
      </div>
      <div class="stat-list">
        <h3>Topp 10 klubber</h3>
        <ol>
          {topp10Klubber.map(([name, count]) => (
            <li><span class="list-name">{name}</span><span class="list-count">{count}</span></li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <!-- Søk og filtrering -->
  <section class="controls" id="controls">
    <div class="search-row">
      <input
        type="search"
        id="search"
        placeholder="Søk etter klubb, land, farge..."
        autocomplete="off"
      />
      <div class="view-toggle" id="view-toggle">
        <button class="toggle-btn active" data-view="grid" title="Kortvisning">▦</button>
        <button class="toggle-btn" data-view="table" title="Tabellvisning">☰</button>
      </div>
    </div>
    <div class="filters">
      <select id="filter-land">
        <option value="">Alle land</option>
        {land.map((l) => <option value={l}>{l}</option>)}
      </select>
      <select id="filter-type">
        <option value="">Alle typer</option>
        {typer.map((t) => <option value={t}>{t}</option>)}
      </select>
      <select id="filter-farge">
        <option value="">Alle farger</option>
        {farger.map((f) => <option value={f}>{f}</option>)}
      </select>
      <select id="filter-tiaar">
        <option value="">Alle tiår</option>
        {tiaar.map((t) => <option value={t}>{t}-tallet</option>)}
      </select>
      <button id="reset-filters" class="reset-btn" hidden>Nullstill</button>
    </div>
    <p class="results-count" id="results-count"></p>
  </section>

  <!-- Kortvisning -->
  <div class="grid" id="grid">
    {allDrakter.map((drakt) => (
      <div
        class="grid-item"
        data-navn={drakt.navn.toLowerCase()}
        data-land={drakt.land}
        data-type={drakt.typeLag}
        data-farge={drakt.farge.toLowerCase()}
        data-aar={drakt.aar}
      >
        <DraktCard drakt={drakt} />
      </div>
    ))}
  </div>

  <!-- Tabellvisning -->
  <div class="table-wrapper" id="table-view" hidden>
    <table>
      <thead>
        <tr>
          <th>Navn</th>
          <th>Sesong</th>
          <th>Land</th>
          <th>Type</th>
          <th>Farge</th>
          <th>Info</th>
        </tr>
      </thead>
      <tbody>
        {allDrakter.map((drakt) => (
          <tr
            class="table-row"
            data-navn={drakt.navn.toLowerCase()}
            data-land={drakt.land}
            data-type={drakt.typeLag}
            data-farge={drakt.farge.toLowerCase()}
            data-aar={drakt.aar}
          >
            <td><a href={`/drakt/${drakt.id}`}>{drakt.navn}</a></td>
            <td>{drakt.aar}</td>
            <td>{drakt.land}</td>
            <td>{drakt.typeLag}</td>
            <td>{drakt.farge}</td>
            <td class="info-cell">{drakt.informasjon}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</Base>

<style>
  .hero {
    text-align: center;
    margin-bottom: 2rem;
  }

  .hero h1 {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 0.25rem;
    letter-spacing: -0.02em;
  }

  .hero p {
    color: var(--color-muted);
    font-size: 1.05rem;
  }

  /* Statistikk */
  .stats {
    margin-bottom: 2.5rem;
    padding: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .stat-cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .stat-card {
    text-align: center;
    padding: 1rem 0.5rem;
    background: var(--color-bg);
    border-radius: var(--radius);
  }

  .stat-number {
    display: block;
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--color-accent);
    line-height: 1.2;
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .stat-lists {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .stat-list h3 {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-muted);
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .stat-list ol {
    list-style: none;
    counter-reset: rank;
  }

  .stat-list li {
    counter-increment: rank;
    display: flex;
    align-items: center;
    padding: 0.35rem 0;
    font-size: 0.9rem;
  }

  .stat-list li::before {
    content: counter(rank) ".";
    width: 1.5rem;
    font-weight: 600;
    color: var(--color-muted);
    font-size: 0.8rem;
  }

  .list-name {
    flex: 1;
  }

  .list-count {
    font-weight: 600;
    color: var(--color-accent);
    font-size: 0.85rem;
  }

  /* Controls */
  .controls {
    margin-bottom: 1.5rem;
  }

  .search-row {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  #search {
    flex: 1;
    padding: 0.65rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    font-size: 0.95rem;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  #search:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
  }

  .view-toggle {
    display: flex;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .toggle-btn {
    padding: 0.65rem 0.85rem;
    border: none;
    background: var(--color-surface);
    cursor: pointer;
    font-size: 1rem;
    color: var(--color-muted);
    transition: background 0.15s, color 0.15s;
  }

  .toggle-btn.active {
    background: var(--color-accent);
    color: white;
  }

  .toggle-btn:hover:not(.active) {
    background: var(--color-bg);
  }

  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  select {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    font-size: 0.85rem;
    background: var(--color-surface);
    cursor: pointer;
    transition: border-color 0.2s;
  }

  select:focus {
    border-color: var(--color-accent);
    outline: none;
  }

  .reset-btn {
    padding: 0.5rem 0.75rem;
    border: none;
    background: none;
    color: var(--color-accent);
    font-size: 0.85rem;
    cursor: pointer;
    font-weight: 500;
  }

  .reset-btn:hover {
    text-decoration: underline;
  }

  .results-count {
    font-size: 0.85rem;
    color: var(--color-muted);
    margin-top: 0.5rem;
  }

  /* Grid visning */
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1rem;
  }

  .grid-item[hidden] {
    display: none;
  }

  /* Tabellvisning */
  .table-wrapper {
    overflow-x: auto;
  }

  .table-wrapper[hidden] {
    display: none;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  thead {
    position: sticky;
    top: 0;
  }

  th {
    text-align: left;
    padding: 0.75rem 0.75rem;
    background: var(--color-surface);
    border-bottom: 2px solid var(--color-border);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-muted);
  }

  td {
    padding: 0.6rem 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  tr:hover td {
    background: var(--color-bg);
  }

  tr[hidden] {
    display: none;
  }

  .info-cell {
    max-width: 200px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .stat-cards {
      grid-template-columns: repeat(2, 1fr);
    }
    .stat-lists {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }
    .search-row {
      flex-direction: column;
    }
    .filters {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const search = document.getElementById("search") as HTMLInputElement;
    const filterLand = document.getElementById("filter-land") as HTMLSelectElement;
    const filterType = document.getElementById("filter-type") as HTMLSelectElement;
    const filterFarge = document.getElementById("filter-farge") as HTMLSelectElement;
    const filterTiaar = document.getElementById("filter-tiaar") as HTMLSelectElement;
    const resetBtn = document.getElementById("reset-filters") as HTMLButtonElement;
    const gridView = document.getElementById("grid")!;
    const tableView = document.getElementById("table-view")!;
    const gridItems = gridView.querySelectorAll<HTMLElement>(".grid-item");
    const tableRows = tableView.querySelectorAll<HTMLElement>(".table-row");
    const resultsCount = document.getElementById("results-count")!;
    const toggleBtns = document.querySelectorAll<HTMLButtonElement>(".toggle-btn");

    // Visningsveksler
    toggleBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        toggleBtns.forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");
        const view = btn.dataset.view;
        if (view === "grid") {
          gridView.hidden = false;
          tableView.hidden = true;
        } else {
          gridView.hidden = true;
          tableView.hidden = false;
        }
      });
    });

    function applyFilters() {
      const query = search.value.toLowerCase().trim();
      const land = filterLand.value;
      const type = filterType.value;
      const farge = filterFarge.value.toLowerCase();
      const tiaar = filterTiaar.value;
      let visible = 0;

      const hasFilters = !!(query || land || type || farge || tiaar);
      resetBtn.hidden = !hasFilters;

      function matchItem(item: HTMLElement) {
        const matchSearch =
          !query ||
          item.dataset.navn?.includes(query) ||
          item.dataset.land?.toLowerCase().includes(query) ||
          item.dataset.farge?.includes(query) ||
          item.dataset.aar?.includes(query);

        const matchLand = !land || item.dataset.land === land;
        const matchType = !type || item.dataset.type === type;
        const matchFarge = !farge || item.dataset.farge?.includes(farge);
        const matchTiaar = !tiaar || (item.dataset.aar || "").match(new RegExp(`${tiaar}\\d`));

        return matchSearch && matchLand && matchType && matchFarge && matchTiaar;
      }

      gridItems.forEach((item) => {
        const show = matchItem(item);
        item.hidden = !show;
        if (show) visible++;
      });

      tableRows.forEach((row) => {
        const show = matchItem(row);
        row.hidden = !show;
      });

      resultsCount.textContent = hasFilters
        ? `Viser ${visible} av ${gridItems.length} drakter`
        : "";
    }

    function resetFilters() {
      search.value = "";
      filterLand.value = "";
      filterType.value = "";
      filterFarge.value = "";
      filterTiaar.value = "";
      applyFilters();
    }

    search.addEventListener("input", applyFilters);
    filterLand.addEventListener("change", applyFilters);
    filterType.addEventListener("change", applyFilters);
    filterFarge.addEventListener("change", applyFilters);
    filterTiaar.addEventListener("change", applyFilters);
    resetBtn.addEventListener("click", resetFilters);
  });
</script>
