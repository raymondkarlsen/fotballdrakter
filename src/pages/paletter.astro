---
import Base from "../layouts/Base.astro";
---

<Base title="Fargepalett-forslag">
  <h1 style="margin-bottom: 2rem;">Fargepalett-forslag</h1>

  <!-- Stadium Green -->
  <section class="palette-section">
    <h2>1. Stadium Green</h2>
    <p class="palette-desc">Inspirert av gressmatta – frisk og naturlig</p>
    <div class="swatches">
      <div class="swatch" style="background: #fafdf7;"><span>Bakgrunn<br>#fafdf7</span></div>
      <div class="swatch" style="background: #ffffff; border: 1px solid #d4e4d4;"><span>Overflate<br>#ffffff</span></div>
      <div class="swatch" style="background: #1a2e1a; color: white;"><span>Tekst<br>#1a2e1a</span></div>
      <div class="swatch" style="background: #5f7a5f; color: white;"><span>Dempet<br>#5f7a5f</span></div>
      <div class="swatch" style="background: #2d8a4e; color: white;"><span>Aksent<br>#2d8a4e</span></div>
      <div class="swatch" style="background: #e8f5e9;"><span>Aksent lys<br>#e8f5e9</span></div>
      <div class="swatch" style="background: #d4e4d4;"><span>Border<br>#d4e4d4</span></div>
    </div>
    <div class="preview" style="background: #fafdf7; border: 1px solid #d4e4d4;">
      <div class="preview-card" style="background: #ffffff; border: 1px solid #d4e4d4;">
        <h3 style="color: #1a2e1a;">Manchester United</h3>
        <p style="color: #5f7a5f;">1998/99 · England</p>
        <span style="background: #e8f5e9; color: #2d8a4e; padding: 2px 8px; border-radius: 4px; font-size: 0.8rem;">Klubb</span>
      </div>
      <div class="preview-stat" style="background: #ffffff; border: 1px solid #d4e4d4;">
        <span style="font-size: 2rem; font-weight: 800; color: #2d8a4e;">425</span>
        <span style="color: #5f7a5f; font-size: 0.75rem; text-transform: uppercase;">Drakter totalt</span>
      </div>
      <div class="preview-bar-track" style="background: #e8f5e9;">
        <div style="width: 75%; height: 100%; background: linear-gradient(90deg, #2d8a4e, #66bb6a); border-radius: 6px;"></div>
      </div>
    </div>
  </section>

  <!-- Midnight Kit -->
  <section class="palette-section">
    <h2>2. Midnight Kit</h2>
    <p class="palette-desc">Mørk og sofistikert – klassiske bortedrakter</p>
    <div class="swatches">
      <div class="swatch" style="background: #f8f9fa;"><span>Bakgrunn<br>#f8f9fa</span></div>
      <div class="swatch" style="background: #ffffff; border: 1px solid #e2e8f0;"><span>Overflate<br>#ffffff</span></div>
      <div class="swatch" style="background: #0f1419; color: white;"><span>Tekst<br>#0f1419</span></div>
      <div class="swatch" style="background: #536471; color: white;"><span>Dempet<br>#536471</span></div>
      <div class="swatch" style="background: #1d4ed8; color: white;"><span>Aksent<br>#1d4ed8</span></div>
      <div class="swatch" style="background: #eff6ff;"><span>Aksent lys<br>#eff6ff</span></div>
      <div class="swatch" style="background: #e2e8f0;"><span>Border<br>#e2e8f0</span></div>
    </div>
    <div class="preview" style="background: #f8f9fa; border: 1px solid #e2e8f0;">
      <div class="preview-card" style="background: #ffffff; border: 1px solid #e2e8f0;">
        <h3 style="color: #0f1419;">Manchester United</h3>
        <p style="color: #536471;">1998/99 · England</p>
        <span style="background: #eff6ff; color: #1d4ed8; padding: 2px 8px; border-radius: 4px; font-size: 0.8rem;">Klubb</span>
      </div>
      <div class="preview-stat" style="background: #ffffff; border: 1px solid #e2e8f0;">
        <span style="font-size: 2rem; font-weight: 800; color: #1d4ed8;">425</span>
        <span style="color: #536471; font-size: 0.75rem; text-transform: uppercase;">Drakter totalt</span>
      </div>
      <div class="preview-bar-track" style="background: #eff6ff;">
        <div style="width: 75%; height: 100%; background: linear-gradient(90deg, #1d4ed8, #60a5fa); border-radius: 6px;"></div>
      </div>
    </div>
  </section>

  <!-- Terracotta Pitch -->
  <section class="palette-section">
    <h2>3. Terracotta Pitch</h2>
    <p class="palette-desc">Varm og jordnær – retro og grus</p>
    <div class="swatches">
      <div class="swatch" style="background: #faf8f5;"><span>Bakgrunn<br>#faf8f5</span></div>
      <div class="swatch" style="background: #ffffff; border: 1px solid #e7e0d6;"><span>Overflate<br>#ffffff</span></div>
      <div class="swatch" style="background: #292117; color: white;"><span>Tekst<br>#292117</span></div>
      <div class="swatch" style="background: #7a6e5e; color: white;"><span>Dempet<br>#7a6e5e</span></div>
      <div class="swatch" style="background: #c2410c; color: white;"><span>Aksent<br>#c2410c</span></div>
      <div class="swatch" style="background: #fff7ed;"><span>Aksent lys<br>#fff7ed</span></div>
      <div class="swatch" style="background: #e7e0d6;"><span>Border<br>#e7e0d6</span></div>
    </div>
    <div class="preview" style="background: #faf8f5; border: 1px solid #e7e0d6;">
      <div class="preview-card" style="background: #ffffff; border: 1px solid #e7e0d6;">
        <h3 style="color: #292117;">Manchester United</h3>
        <p style="color: #7a6e5e;">1998/99 · England</p>
        <span style="background: #fff7ed; color: #c2410c; padding: 2px 8px; border-radius: 4px; font-size: 0.8rem;">Klubb</span>
      </div>
      <div class="preview-stat" style="background: #ffffff; border: 1px solid #e7e0d6;">
        <span style="font-size: 2rem; font-weight: 800; color: #c2410c;">425</span>
        <span style="color: #7a6e5e; font-size: 0.75rem; text-transform: uppercase;">Drakter totalt</span>
      </div>
      <div class="preview-bar-track" style="background: #fff7ed;">
        <div style="width: 75%; height: 100%; background: linear-gradient(90deg, #c2410c, #f97316); border-radius: 6px;"></div>
      </div>
    </div>
  </section>
</Base>

<style>
  .palette-section {
    margin-bottom: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--color-border);
  }

  .palette-section:last-child {
    border-bottom: none;
  }

  .palette-section h2 {
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
  }

  .palette-desc {
    color: var(--color-muted);
    margin-bottom: 1.25rem;
  }

  .swatches {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .swatch {
    width: 100px;
    height: 80px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.65rem;
    text-align: center;
    line-height: 1.4;
  }

  .preview {
    padding: 1.5rem;
    border-radius: 12px;
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .preview-card {
    padding: 1rem;
    border-radius: 8px;
    min-width: 180px;
  }

  .preview-card h3 {
    font-size: 1rem;
    margin-bottom: 0.25rem;
  }

  .preview-card p {
    font-size: 0.85rem;
    margin-bottom: 0.5rem;
  }

  .preview-stat {
    padding: 1rem 1.5rem;
    border-radius: 8px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .preview-bar-track {
    height: 24px;
    border-radius: 6px;
    flex: 1;
    min-width: 150px;
  }
</style>
