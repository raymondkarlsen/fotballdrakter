---
import Base from "../../layouts/Base.astro";
import Icon from "../../components/Icon.astro";
import drakter from "../../data/drakter.json";
import type { Drakt } from "../../types";

export function getStaticPaths() {
  return (drakter as Drakt[]).map((drakt) => ({
    params: { id: drakt.id },
    props: { drakt },
  }));
}

const { drakt } = Astro.props as { drakt: Drakt };

import { readdirSync } from 'fs';
import { resolve } from 'path';
const imageDir = resolve(process.cwd(), 'public/images/drakter');
let localImagePath: string | null = null;
try {
  const files = readdirSync(imageDir);
  const match = files.find(f => f.startsWith(drakt.id + '.'));
  if (match) {
    localImagePath = `${import.meta.env.BASE_URL}/images/drakter/${match}`;
  }
} catch {}

const hasImage = localImagePath || (drakt.bildeUrl && !drakt.bildeUrl.includes("illustrasjon"));
const imageSrc = localImagePath || drakt.bildeUrl;
---

<Base title={`${drakt.navn} – Fotballdrakter`}>
  <a href={import.meta.env.BASE_URL} class="back">← Tilbake til oversikten</a>

  <article class="detail">
    <div class="detail-image">
      {hasImage ? (
        <img src={imageSrc} alt={drakt.navn} />
      ) : (
        <div class="placeholder"><Icon name="shirt" size={64} /></div>
      )}
    </div>

    <div class="detail-info">
      <h1>{drakt.navn}</h1>

      <dl class="meta">
        {drakt.aar && (
          <>
            <dt>Sesong</dt>
            <dd>{drakt.aar}</dd>
          </>
        )}
        {drakt.land && (
          <>
            <dt>Land</dt>
            <dd>{drakt.land}</dd>
          </>
        )}
        {drakt.typeLag && (
          <>
            <dt>Type</dt>
            <dd>{drakt.typeLag}</dd>
          </>
        )}
        {drakt.farge && (
          <>
            <dt>Farge</dt>
            <dd>{drakt.farge}</dd>
          </>
        )}
        {drakt.informasjon && (
          <>
            <dt>Info</dt>
            <dd>{drakt.informasjon}</dd>
          </>
        )}
      </dl>

      {drakt.kitArchiveUrl && (
        <a href={drakt.kitArchiveUrl} target="_blank" rel="noopener" class="external-link">
          Se på Football Kit Archive ↗
        </a>
      )}
    </div>
  </article>
</Base>

<style>
  .back {
    display: inline-block;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
    color: var(--color-muted);
  }

  .back:hover {
    color: var(--color-accent);
  }

  .detail {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
  }

  .detail-image {
    background: #f0f0f0;
    border-radius: var(--radius);
    aspect-ratio: 3 / 4;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .detail-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .placeholder {
    font-size: 5rem;
    opacity: 0.2;
  }

  .detail-info h1 {
    font-size: 1.75rem;
    margin-bottom: 1rem;
  }

  .meta {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.5rem 1rem;
    margin-bottom: 1.5rem;
  }

  .meta dt {
    font-weight: 600;
    color: var(--color-muted);
    font-size: 0.875rem;
  }

  .meta dd {
    font-size: 0.95rem;
  }

  .external-link {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: var(--color-accent);
    color: white;
    border-radius: var(--radius);
    font-size: 0.875rem;
    transition: opacity 0.2s;
  }

  .external-link:hover {
    opacity: 0.85;
    text-decoration: none;
  }

  @media (max-width: 700px) {
    .detail {
      grid-template-columns: 1fr;
    }
  }
</style>
