---
export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="no">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="En samling av over 400 fotballdrakter fra hele verden" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <nav>
        <a href={import.meta.env.BASE_URL} class="logo">⚽ Fotballdrakter</a>
        <span class="count">425 drakter</span>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>En personlig samling av fotballdrakter fra hele verden.</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --color-bg: #fafdf7;
    --color-surface: #ffffff;
    --color-text: #1a2e1a;
    --color-muted: #5f7a5f;
    --color-border: #d4e4d4;
    --color-accent: #2d8a4e;
    --color-accent-light: #e8f5e9;
    --radius: 8px;
    --max-width: 1200px;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    background: var(--color-bg);
    color: var(--color-text);
    line-height: 1.6;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  header {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    padding: 1rem 2rem;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  header nav {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-size: 1.25rem;
    font-weight: 700;
    text-decoration: none;
    color: var(--color-text);
  }

  .count {
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  main {
    flex: 1;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem;
    width: 100%;
  }

  footer {
    border-top: 1px solid var(--color-border);
    padding: 2rem;
    text-align: center;
    color: var(--color-muted);
    font-size: 0.875rem;
  }

  a {
    color: var(--color-accent);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }
</style>
